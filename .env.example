# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789]

# PostgreSQL
DB_USER=gorba
DB_PASS=gorba_secret_change_me
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gorba_bot

# Bot runtime: polling | webhook
BOT_MODE=polling
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_webhook_secret
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Admin API
API_HOST=0.0.0.0
API_PORT=18000
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:5173","http://localhost:13000","http://localhost:3000","http://localhost"]

# Frontend: leave empty for same-origin /api proxy (Docker nginx). Vite dev uses vite.config.js proxy.
VITE_API_URL=
# Baked into frontend at build time (docker compose passes API_SECRET_KEY as VITE_API_SECRET_KEY).
VITE_API_SECRET_KEY=change-me-in-production
