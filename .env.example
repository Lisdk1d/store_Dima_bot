# Deployment environment: production (strict secret checks) | development
ENV=production

# Telegram bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789]
# Admin panel is deployed separately on Vercel (see ../Gorba_admin_panel) — point
# this at wherever it's actually hosted.
ADMIN_PANEL_URL=https://admin-panel-eight-bay-51.vercel.app

# PostgreSQL
DB_USER=gorba
# Set a strong unique password. The placeholder below is REJECTED when ENV=production.
DB_PASS=CHANGE_ME_strong_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gorba_bot

# Bot runtime
BOT_MODE=polling
WEBAPP_PORT=18080
# Required (non-empty) when BOT_MODE=webhook — Telegram secret token for /webhook.
WEBHOOK_SECRET=

# FastAPI admin API
API_PORT=18000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Min 16 chars; the placeholder is REJECTED when ENV=production.
API_SECRET_KEY=CHANGE_ME_generate_a_random_key
# Admin panel auth: initdata (Telegram WebApp, recommended) | devkey (X-API-Key, dev only)
ADMIN_AUTH_MODE=devkey
# Must include the Vercel origin the admin panel is actually served from, or
# the browser will block its requests to this API with a CORS error.
CORS_ORIGINS=["http://localhost:5173","http://localhost:13000","http://localhost:3000","http://localhost","https://admin-panel-eight-bay-51.vercel.app"]

# Generic provider webhook (HMAC-signed providers only — NOT used by YooKassa,
# whose webhooks are unsigned; leave empty unless you wire up such a provider).
PAYMENT_WEBHOOK_SECRET=

# --- Online payment (YooKassa) ---
# Leave YOOKASSA_SHOP_ID empty to disable online payment (checkout offers only
# "cash on delivery"). Get shopId/secretKey from https://yookassa.ru after
# registering a shop.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=CHANGE_ME_generate_a_random_key
# Same public domain as ADMIN_PANEL_URL — nginx routes /pay/ and /webhooks/yookassa
# to the payment-page service on this same host (see deploy/nginx.conf).
PAYMENT_PAGE_URL=https://your-domain.example
PAYMENT_API_PORT=18001
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Distinct from API_SECRET_KEY/PAYMENT_WEBHOOK_SECRET. Min 16 chars; required
# (and the placeholder REJECTED) when YOOKASSA_SHOP_ID is set and ENV=production.
PAYMENT_LINK_SECRET=CHANGE_ME_generate_a_random_key
PAYMENT_LINK_MAX_AGE=1800
