# Deployment environment: production (strict secret checks) | development
ENV=production

# Telegram bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789]
ADMIN_PANEL_URL=https://your-domain.example

# PostgreSQL
DB_USER=gorba
# Set a strong unique password. The placeholder below is REJECTED when ENV=production.
DB_PASS=CHANGE_ME_strong_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gorba_bot

# Bot runtime
BOT_MODE=polling
WEBAPP_PORT=18080
# Required (non-empty) when BOT_MODE=webhook — Telegram secret token for /webhook.
WEBHOOK_SECRET=

# FastAPI admin API
API_PORT=18000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Min 16 chars; the placeholder is REJECTED when ENV=production.
API_SECRET_KEY=CHANGE_ME_generate_a_random_key
# Admin panel auth: initdata (Telegram WebApp, recommended) | devkey (X-API-Key, dev only)
ADMIN_AUTH_MODE=initdata
CORS_ORIGINS=["http://localhost:5173","http://localhost:13000","http://localhost:3000","http://localhost"]

# Frontend build (Docker) — NEVER put API_SECRET_KEY here; the panel authenticates
# via Telegram WebApp initData. VITE_API_URL empty = same-origin /api proxy.
VITE_API_URL=
