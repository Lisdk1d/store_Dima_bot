# Telegram bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789]
ADMIN_PANEL_URL=https://your-domain.example

# PostgreSQL
DB_USER=gorba
DB_PASS=gorba_secret
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gorba_bot

# Bot runtime
BOT_MODE=polling
WEBAPP_PORT=18080

# FastAPI admin API
API_PORT=18000
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:5173","http://localhost:13000","http://localhost:3000","http://localhost"]

# Frontend build (Docker)
VITE_API_URL=
